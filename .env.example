# ═══════════════════════════════════════════════════════════════
# AI TEAM SYSTEM — Конфигурация
# Скопируй в .env и заполни нужные ключи
# ═══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────
# GitHub Models — БЕСПЛАТНЫЙ vision анализ скриншотов (GPT-4o)
# 50 запросов в день, работает в РФ
# Получить: github.com/settings/tokens → Generate new token (classic)
#           Никаких галочек не нужно → скопируй → вставь ниже
# ─────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────
# БЕСПЛАТНЫЕ API (рекомендую!)
# ─────────────────────────────────────────────────────────────

# Groq — БЫСТРЫЙ! Бесплатно навсегда
# https://console.groq.com/keys
GROQ_API_KEY=

# DeepSeek — 5 миллионов токенов бесплатно!
# https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# Google AI Studio — Gemini 2.5 Pro бесплатно
# https://aistudio.google.com/app/apikey
GOOGLE_AI_STUDIO_KEY=

# OpenRouter — агрегатор (DeepSeek R1, Llama бесплатно)
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# xAI Grok — $25 кредитов
# https://console.x.ai/
XAI_API_KEY=

# ─────────────────────────────────────────────────────────────
# ПЛАТНЫЕ API (опционально)
# ─────────────────────────────────────────────────────────────

# Anthropic Claude — $5 бесплатно
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI GPT-4
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ─────────────────────────────────────────────────────────────
# OLLAMA (локальные модели)
# ─────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# ─────────────────────────────────────────────────────────────
# НАСТРОЙКИ
# ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
HARDWARE_PROFILE=medium
AI_MODE=local
DB_PATH=./data/ai_team.db
PROJECTS_DIR=~/projects
SECRET_KEY=
